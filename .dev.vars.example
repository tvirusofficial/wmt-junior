# ⚠️ ဒီ file ကို Git မတင်ရ (.gitignore မှာ ပါပြီး)
# Local development အတွက် သာသုံးပါ
# Cloudflare Dashboard မှာ Secrets အနေနဲ့ ထည့်ရမည်

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_here

GEMINI_API_KEY=your_gemini_api_key_here

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ကိုကို Telegram ID နှင့် ကောင်မလေး Telegram ID — comma separated
ALLOWED_USER_IDS=123456789,987654321

# ကိုကို Telegram ID (Admin)
ADMIN_ID=123456789

# Admin Panel ဝင်ဖို့ password (random string တစ်ခု သတ်မှတ်ပါ)
ADMIN_SECRET_TOKEN=your_strong_random_admin_token_here
